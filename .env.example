# Site configuration
ticket_site=https://example.com/tickets
fb_email=you@example.com
fb_password=change-me
eventim_url=https://eventim.example.com
eventim_email=you@example.com
eventim_password=change-me

# Email notification
EMAIL_PROVIDER=smtp
EMAIL_SENDER=you@example.com
EMAIL_RECIPIENT=customer@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=change-me

# Phase 1/2 runtime
PYTICKETS_DB_PATH=data/pytickets.db
PYTICKETS_URL_CACHE=data/url_cache.json
PYTICKETS_URL_CACHE_TTL_DAYS=30
PYTICKETS_NOTIFY_MODE=first
PYTICKETS_DEBUG_DIR=data/debug

# Scheduler/API
PYTICKETS_SCHEDULE_SITE=dutch_tickets
PYTICKETS_SCHEDULE_URL=https://example.com/tickets
PYTICKETS_SCHEDULE_INTERVAL_HOURS=2
PYTICKETS_API_HOST=0.0.0.0
PYTICKETS_API_PORT=8000

# Optional proxy rotation
PYTICKETS_PROXIES=
PYTICKETS_PROXY_STRATEGY=round_robin
PYTICKETS_PROXY_MAX_FAILURES=3
